# ──────────────────────────────────────────────────────────────
# v2stc frontend (Next.js) — TEMPLATE environment variables
#
# DEV (lokal):   cp .env.local.example .env.local  lalu edit.
# PRODUKSI:      JANGAN pakai file ini di Vercel — masukкан tiap
#                variable di Vercel > Project Settings > Environment
#                Variables (Production), lalu Redeploy.
#
# Semua var berprefix NEXT_PUBLIC_ TER-EXPOSE ke browser (publik).
# Karena itu HANYA pakai Supabase ANON key di sini, JANGAN service_role.
# ──────────────────────────────────────────────────────────────

# URL backend NestJS (tanpa trailing slash — kode menambah /api/v1 sendiri)  [WAJIB]
NEXT_PUBLIC_API_URL=https://api.domainku.com

# Supabase (Dashboard > Settings > API)  [WAJIB]
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_ANON_PUBLIC_KEY_DISINI

# API Stockity (opsional — default sudah https://api.stockity.id/ kalau dikosongkan)
NEXT_PUBLIC_STOCKITY_API_URL=https://api.stockity.id/
